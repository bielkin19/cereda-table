{
  "name": "@bielkin19/cereda-table",
  "version": "0.1.8",
  "description": "Enterprise-grade React DataTable with sorting, filtering, grouping, DnD, virtualization and saved views.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./locales": {
      "types": "./dist/locales.d.ts",
      "import": "./dist/locales.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint eslint.config.js src vitest.setup.ts --max-warnings 0",
    "test": "vitest run --configLoader native --pool vmThreads",
    "test:e2e": "playwright test",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@dnd-kit/core": ">=6.0.0",
    "@dnd-kit/sortable": ">=10.0.0",
    "@dnd-kit/utilities": ">=3.0.0",
    "@radix-ui/react-checkbox": ">=1.0.0",
    "@radix-ui/react-popover": ">=1.0.0",
    "@radix-ui/react-scroll-area": ">=1.0.0",
    "@radix-ui/react-select": ">=2.0.0",
    "@tanstack/react-table": ">=8.0.0",
    "@tanstack/react-virtual": ">=3.0.0",
    "lucide-react": ">=1.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "react",
    "table",
    "data-table",
    "datagrid",
    "tanstack",
    "dnd",
    "grouping",
    "virtualization",
    "enterprise"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bielkin19/cereda-table.git"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
